{
  "name": "e2e",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "e2e": "node ./scripts/run-chromium-e2e.js",
    "e2e:firefox": "npm run patch:playwright-firefox-worker-websocket && node ./node_modules/@lvce-editor/test-with-playwright/bin/test-with-playwright.js --only-extension=. --test-path=. --browser=firefox",
    "e2e:firefox:headless": "npm run patch:playwright-firefox-worker-websocket && node ./node_modules/@lvce-editor/test-with-playwright/bin/test-with-playwright.js --only-extension=. --test-path=. --browser=firefox --headless",
    "e2e:headless": "node ./scripts/run-chromium-e2e.js --headless",
    "e2e:webkit": "node ./scripts/run-webkit-e2e.js",
    "e2e:webkit:headless": "node ./scripts/run-webkit-e2e.js --headless",
    "patch:playwright-firefox-worker-websocket": "node ./scripts/patch-playwright-firefox-worker-websocket.js",
    "type-check": "tsc"
  },
  "devDependencies": {
    "@lvce-editor/test-with-playwright": "^22.7.1"
  }
}
