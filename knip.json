{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": ["*.js"],
      "ignoreDependencies": ["@lerna/legacy-package-management"]
    },
    "packages/build": {
      "project": ["src/**/*.js", "src/**/*.ts"],
      "ignoreDependencies": ["@lvce-editor/verror", "esbuild", "playwright"]
    },
    "packages/e2e": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/main-area-worker": {
      "entry": ["src/mainAreaWorkerMain.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/server": {
      "project": ["src/**/*.js"]
    }
  }
}
